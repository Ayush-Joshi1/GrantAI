# =========================
# Grant Agent - Environment
# =========================

# ---- App ----
APP_ENV=local
APP_NAME=grant-agent
API_BASE_URL=http://localhost:8000

# ---- Backend server ----
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ---- Auth (optional for hackathon) ----
JWT_SECRET=change-me
JWT_ISSUER=grant-agent

# ---- Database (recommended: Postgres) ----
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/grant_agent

# ---- Object Storage (IBM Cloud Object Storage) ----
COS_ENDPOINT=
COS_API_KEY_ID=
COS_INSTANCE_CRN=
COS_BUCKET_NAME=grant-agent

# ---- Vector store / RAG ----
VECTOR_INDEX_PATH=./artifacts/faiss/grants.index
EMBEDDINGS_PROVIDER=ibm_watsonx

# ---- IBM watsonx.ai (Granite) ----
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=
GRANITE_MODEL_ID=

# ---- IBM watsonx Assistant ----
WATSONX_ASSISTANT_API_KEY=
WATSONX_ASSISTANT_URL=
WATSONX_ASSISTANT_ID=

# ---- IBM watsonx Orchestrate ----
WATSONX_ORCHESTRATE_API_KEY=
WATSONX_ORCHESTRATE_URL=

# ---- Background jobs / queue (optional) ----
REDIS_URL=redis://localhost:6379/0

