              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Inputs",
            "description": "Workflow inputs mapped to the Orchestrate definition"
          }
        },
        "type": "object",
        "required": [
          "workflow_id"
        ],
        "title": "OrchestrateExecuteRequest"
      },
      "OrchestrateExecuteResponse": {
        "properties": {
          "execution_id": {
            "type": "string",
            "title": "Execution Id",
            "description": "Orchestrate execution identifier"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Orchestrate execution status"
          },
          "output": {
            "additionalProperties": true,
            "type": "object",
            "title": "Output",
            "description": "Workflow execution output payload"
          }
        },
        "type": "object",
        "required": [
          "execution_id",
          "status"
        ],
        "title": "OrchestrateExecuteResponse"
      },
