{
  "openapi": "3.1.0",
  "info": {
    "title": "Grant Agent API",
    "description": "AI platform for grant discovery, eligibility checks, and proposal generation.",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "ChatTurnRequest": {
        "properties": {
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id",
            "description": "Client-provided session id (optional)"
          },
          "message": {
            "type": "string",
            "maxLength": 5000,
            "minLength": 1,
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ChatTurnRequest"
      },
      "ChatTurnResponse": {
        "properties": {
          "session_id": {
            "type": "string",
            "title": "Session Id"
          },
          "reply": {
            "type": "string",
            "title": "Reply"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "reply"
        ],
        "title": "ChatTurnResponse"
      },
      "DeadlineRequest": {
        "properties": {
          "selected_grant": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SelectedGrantInput"
              },
              {
                "type": "null"
              }
            ],
            "description": "Trusted grant context for deadline analysis"
          },
          "grant_context": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 16000
              },
              {
                "type": "null"
              }
            ],
            "title": "Grant Context",
            "description": "Optional additional grant context"
          }
        },
        "type": "object",
        "title": "DeadlineRequest"
      },
      "DeadlineResponse": {
        "properties": {
          "deadline_status": {
            "$ref": "#/components/schemas/DeadlineStatus",
            "default": "unknown"
          },
          "deadline": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Deadline",
            "description": "Deadline text when available"
          },
          "days_remaining": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Days Remaining",
            "description": "Days remaining when a supported deadline is known"
          },
          "important_dates": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Important Dates"
          },
          "recommended_action": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recommended Action"
          },
          "answer": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Answer",
            "description": "Grounded deadline analysis"
          },
          "analysis": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Analysis"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/SourceResponse"
            },
            "type": "array",
            "title": "Sources"
          }
        },
        "type": "object",
        "title": "DeadlineResponse"
      },
      "DeadlineStatus": {
        "type": "string",
        "enum": [
          "known",
          "unknown"
        ],
        "title": "DeadlineStatus"
      },
      "EligibilityCheckRequest": {
        "properties": {
          "grant_id": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200
              },
              {
                "type": "null"
              }
            ],
            "title": "Grant Id",
            "description": "Optional legacy grant identifier"
          },
          "startup_profile_id": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200
              },
              {
                "type": "null"
              }
            ],
            "title": "Startup Profile Id",
            "description": "Optional legacy startup profile identifier"
          },
          "answers": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Answers",
            "description": "Legacy answer map for placeholder services"
          },
          "selected_grant": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SelectedGrantInput"
              },
              {
                "type": "null"
              }
            ],
            "description": "Trusted grant context for eligibility analysis"
          },
          "startup_profile": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/StartupProfileInput"
              },
              {
                "type": "null"
              }
            ],
            "description": "Structured startup profile for eligibility analysis"
          },
          "additional_answers": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Additional Answers",
            "description": "Structured additional answers"
          },
          "additional_context": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 12000
              },
              {
                "type": "null"
              }
            ],
            "title": "Additional Context",
            "description": "Additional context for eligibility analysis"
          }
        },
        "type": "object",
        "title": "EligibilityCheckRequest"
      },
      "EligibilityCheckResponse": {
        "properties": {
          "eligibility_status": {
            "$ref": "#/components/schemas/EligibilityStatus",
            "default": "insufficient_information"
          },
          "answer": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Answer",
            "description": "Grounded eligibility analysis"
          },
          "analysis": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Analysis",
            "description": "Alternative analysis field for richer responses"
          },
          "reasons": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Reasons"
          },
          "missing_requirements": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Missing Requirements"
          },
          "recommendations": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Recommendations"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/SourceResponse"
            },
            "type": "array",
            "title": "Sources"
          },
          "decision": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "eligible",
                  "not_eligible",
                  "unknown"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Decision"
          },
          "confidence": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 1.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence"
          },
          "missing_info": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Missing Info"
          }
        },
        "type": "object",
        "title": "EligibilityCheckResponse"
      },
      "EligibilityStatus": {
        "type": "string",
        "enum": [
          "eligible",
          "likely_eligible",
          "not_eligible",
          "insufficient_information"
        ],
        "title": "EligibilityStatus"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HistoryItem": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "detail": {
            "type": "string",
            "title": "Detail"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "title": "Time"
          }
        },
        "type": "object",
        "required": [
          "type",
          "title",
          "detail",
          "time"
        ],
        "title": "HistoryItem"
      },
      "HistoryResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/HistoryItem"
            },
