            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "items"
        ],
        "title": "HistoryResponse"
      },
      "NotificationPriority": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ],
        "title": "NotificationPriority"
      },
      "NotificationRequest": {
        "properties": {
          "selected_grant": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SelectedGrantInput"
              },
              {
                "type": "null"
              }
            ],
            "description": "Trusted grant context when available"
          },
          "grant_context": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Grant Context",
            "description": "Optional grant context used for the notification"
          },
          "deadline_context": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Deadline Context",
            "description": "Optional deadline information for the notification"
          },
          "action_context": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Action Context",
            "description": "Optional action or application context for the notification"
          },
          "notification_preferences": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 4000
              },
              {
                "type": "null"
              }
            ],
            "title": "Notification Preferences",
            "description": "User notification preferences or context"
          }
        },
        "type": "object",
        "title": "NotificationRequest"
      },
      "NotificationResponse": {
        "properties": {
          "notification_type": {
            "$ref": "#/components/schemas/NotificationType",
            "default": "general_update"
          },
          "priority": {
            "$ref": "#/components/schemas/NotificationPriority",
            "default": "medium"
          },
          "title": {
            "type": "string",
            "title": "Title",
            "default": "Funding update"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "default": ""
          },
          "answer": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Answer",
            "description": "Grounded notification guidance"
          },
          "recommended_schedule": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recommended Schedule"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/SourceResponse"
            },
            "type": "array",
            "title": "Sources"
          }
        },
        "type": "object",
        "title": "NotificationResponse"
      },
      "NotificationType": {
        "type": "string",
        "enum": [
          "funding_action",
          "deadline_reminder",
          "general_update"
        ],
        "title": "NotificationType"
      },
      "OrchestrateExecuteRequest": {
        "properties": {
          "workflow_id": {
            "type": "string",
